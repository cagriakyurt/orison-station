#!/bin/bash
# orison-broadcast: Manages FM broadcasting via PiFmRds with dynamic RDS support

# Configuration
# Determine directories dynamically based on script location (following symlinks)
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
BASE_DIR="$(dirname "$SCRIPT_DIR")"
WAV_PATH="$BASE_DIR/tmp/orison_radio.wav"
PI_FM_RDS="$HOME/PiFmRds/src/pi_fm_rds"
FREQ="107.9"
LOG_FILE="$BASE_DIR/web/actions.log"

# Default RDS Values
PS="ORISON"
RT="ATTENTION"
DURATION=""

# Parse command line options
while [[ "$#" -gt 0 ]]; do
    case $1 in
        --duration) DURATION="$2"; shift ;;
        --ps) PS="$2"; shift ;;
        --rt) RT="$2"; shift ;;
        --freq) FREQ="$2"; shift ;;
        *) echo "Unknown parameter: $1" >&2; exit 1 ;;
    esac
    shift
done

# Ensure RDS PS is uppercase and limited to 8 characters (pi_fm_rds restriction)
PS=$(echo "$PS" | tr '[:lower:]' '[:upper:]' | cut -c 1-8)
# Ensure RDS RT is limited to 64 characters
RT=$(echo "$RT" | cut -c 1-64)

echo "[$(date '+%Y-%m-%d %H:%M:%S')] Starting FM Broadcast on ${FREQ} MHz (RDS PS: ${PS}, RT: ${RT})..." >> "$LOG_FILE"

# Pre-emptive cleanup: ensure no other instances of pi_fm_rds are running
sudo pkill -INT pi_fm_rds 2>/dev/null
sleep 0.2

# Check if WAV exists
if [ ! -f "$WAV_PATH" ]; then
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] ERROR: Audio file $WAV_PATH not found." >> "$LOG_FILE"
    exit 1
fi

# Define cleanup function to cleanly deactivate DMA engine and restore GPIO
cleanup() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Stopping FM Broadcast (received signal)..." >> "$LOG_FILE"
    sudo pkill -INT pi_fm_rds 2>/dev/null
    exit 0
}

# Trap SIGINT and SIGTERM
trap cleanup INT TERM

# Start PiFmRds using a non-seekable pipe. 
# This forces the binary to fail rewinding on EOF, terminating cleanly after playing once.
# $! will contain the PID of the last process in the pipeline (pi_fm_rds)
cat "$WAV_PATH" | sudo "$PI_FM_RDS" -freq "$FREQ" -audio - -ps "$PS" -rt "$RT" >> "$LOG_FILE" 2>&1 &
PID=$!

# Handle duration if supplied
if [ -n "$DURATION" ]; then
    (
        sleep "$DURATION"
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Duration (${DURATION}s) limit reached. Stopping broadcast..." >> "$LOG_FILE"
        kill -INT "$PID" 2>/dev/null
        sudo pkill -INT pi_fm_rds 2>/dev/null
    ) &
fi

# Wait for the background process to finish
wait $PID
echo "[$(date '+%Y-%m-%d %H:%M:%S')] Broadcast session ended." >> "$LOG_FILE"
